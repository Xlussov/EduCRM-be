CONFIG_PATH=config/local.yaml

JWT_SECRET=jwt-secret-key
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

POSTGRES_USER=postgres-user
POSTGRES_PASSWORD=postgres-password
POSTGRES_DB_NAME=postgres-db
POSTGRES_PORT=5432

DATABASE_URL=postgres://postgres-user:postgres-password@localhost:5432/postgres-db?sslmode=disable